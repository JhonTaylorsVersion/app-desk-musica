{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos por defecto para la app",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-toggle-maximize",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-start-dragging",
    "dialog:default",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read",
    "fs:allow-read-dir",
    "shell:default",
    "allow-core",
    "allow-spotiflac"
  ]
}
